<Window x:Class="VideoSpike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ffme="clr-namespace:Unosquare.FFME;assembly=ffme.win"
        Title="FFME Spike" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <ffme:MediaElement x:Name="Media" Grid.Row="0" Background="Black" LoadedBehavior="Play" />
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Play" Click="Play_Click" Margin="5" Padding="10,5" />
            <Button Content="Pause" Click="Pause_Click" Margin="5" Padding="10,5" />
            <Button Content="Seek +5s" Click="Seek_Click" Margin="5" Padding="10,5" />
            <Button Content="Open RTSP" Click="Open_Click" Margin="5" Padding="10,5" />
        </StackPanel>
    </Grid>
</Window>
