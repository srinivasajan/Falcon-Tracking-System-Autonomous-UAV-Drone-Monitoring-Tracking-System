{
  "DroneControl": {
    "Mode": "Simulation",
    "RuntimeManagement": {
      "RuntimeRoot": "%LOCALAPPDATA%\\DroneControl\\runtimes",
      "HealthCheckIntervalSeconds": 30
    },
    "PX4": {
      "ConnectionMode": "ManagedLocal",
      "StartupScriptRelativePath": "etc\\init.d-posix\\rcS",
      "Model": "x500",
      "World": "default",
      "StartupDelaySeconds": 3
    },
    "MAVSDK": {
      "ConnectionMode": "ManagedLocal",
      "GrpcAddress": "http://127.0.0.1:50051",
      "GrpcPort": 50051,
      "SystemAddress": "udp://:14540",
      "ConnectionTimeoutSeconds": 30
    },
    "Storage": {
      "UseLocalApplicationData": true
    }
  }
}
