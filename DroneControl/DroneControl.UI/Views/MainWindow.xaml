<Window x:Class="DroneControl.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        xmlns:ffme="clr-namespace:Unosquare.FFME;assembly=ffme.win"
        Title="DroneControl"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="DroneControl" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="Provider-based operations dashboard" FontSize="14" Foreground="#667085" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Start Providers" Command="{Binding StartProvidersCommand}" Padding="18,9" Margin="0,0,10,0" />
                <Button Content="Stop" Command="{Binding StopProvidersCommand}" Padding="18,9" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Dashboard">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="#101820" CornerRadius="8" Padding="16" Margin="0,0,16,16">
                <Grid>
                    <TextBlock Text="PROVIDER CAMERA FEED"
                               Foreground="#B7C9D1"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top" />
                    <Grid Margin="0,32,0,0">
                        <ffme:MediaElement x:Name="LiveVideo" Background="#17242E" LoadedBehavior="Play" />
                        <Canvas Background="Transparent">
                            <ItemsControl ItemsSource="{Binding Detections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.LockTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderBrush="#35D0BA"
                                            BorderThickness="2"
                                            Width="{Binding Width}"
                                            Height="{Binding Height}">
                                        <StackPanel VerticalAlignment="Top" Background="#CC101820">
                                            <TextBlock Text="{Binding ObjectType}" Foreground="White" FontWeight="SemiBold" Margin="4,2" />
                                            <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}" Foreground="#35D0BA" Margin="4,0,4,2" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding FrameLabel}"
                                   Canvas.Left="16"
                                   Canvas.Bottom="16"
                                   Foreground="#B7C9D1"
                                   FontFamily="Consolas" />
                        </Canvas>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Drone Status" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,14" />
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,18" />
                    <ProgressBar Value="{Binding BatteryPercent, Mode=OneWay}" Maximum="100" Height="18" />
                    <TextBlock Text="{Binding BatteryLabel}" Margin="0,6,0,18" />
                    <UniformGrid Columns="2" Rows="4">
                        <TextBlock Text="Latitude" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Latitude}" TextAlignment="Right" />
                        <TextBlock Text="Longitude" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Longitude}" TextAlignment="Right" />
                        <TextBlock Text="Speed" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Speed}" TextAlignment="Right" />
                        <TextBlock Text="Altitude" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Altitude}" TextAlignment="Right" />
                    </UniformGrid>
                    <TextBlock Text="Flight Mode" FontWeight="SemiBold" Margin="0,18,0,4" />
                    <TextBlock Text="{Binding FlightMode}" FontSize="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16" />
                    <TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,15,0,10" />
                    <UniformGrid Columns="2">
                        <Button Content="Arm" Command="{Binding ArmCommand}" Padding="12,8" Margin="0,0,4,4" />
                        <Button Content="Takeoff" Command="{Binding TakeoffCommand}" Padding="12,8" Margin="4,0,0,4" />
                        <Button Content="Disarm" Command="{Binding DisarmCommand}" Padding="12,8" Margin="0,4,4,0" />
                        <Button Content="Land" Command="{Binding LandCommand}" Padding="12,8" Margin="4,4,0,0" />
                    </UniformGrid>
                        
                    <Border Background="#101820" CornerRadius="8" Padding="10" Margin="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="Session Recording" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding RecordingStatusLabel}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center" />
                            <UniformGrid Columns="2">
                                <Button Content="Start Rec" Command="{Binding StartRecordingCommand}" Padding="12,8" Margin="0,0,4,0" Background="#1B4D3E" />
                                <Button Content="Stop Rec" Command="{Binding StopRecordingCommand}" Padding="12,8" Margin="4,0,0,0" Background="#7B2CBF" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18" Margin="0,0,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Target Lock" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TargetLockLabel}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding TargetConfidenceLabel}" Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Mission Planning" FontSize="18" FontWeight="SemiBold" />
                        <Button Content="Add Waypoint" Command="{Binding AddWaypointCommand}" Padding="12,8" Margin="0,10,0,8" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding WaypointSummary}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Replay" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Replay is provider-backed: FFmpeg/GStreamer for media and SQLite for telemetry." TextWrapping="Wrap" Margin="0,10,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Telemetry" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ItemsControl ItemsSource="{Binding TelemetryLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Margin="0,0,0,5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
            </TabItem>
            
            <TabItem Header="Mission Planner">
                <Grid Background="{StaticResource SurfaceBrush}" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Margin="0,0,14,0" Background="#101820">
                        <mapsui:MapControl x:Name="MapControl" />
                    </Border>
                    
                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Mission Planning" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="1" Text="Click the map to place waypoints." Foreground="#667085" Margin="0,0,0,10" TextWrapping="Wrap" />
                            
                            <ListBox Grid.Row="2" ItemsSource="{Binding MissionWaypoints}" SelectedItem="{Binding SelectedWaypoint}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#17242E" CornerRadius="4" Padding="10" Margin="0,0,0,5" MinWidth="260">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Sequence, StringFormat=Waypoint {0}}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                <TextBlock Text="{Binding Latitude, StringFormat=Lat: {0:F5}}" Foreground="#B7C9D1" />
                                                <TextBlock Text="{Binding Longitude, StringFormat=Lon: {0:F5}}" Foreground="#B7C9D1" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <StackPanel Grid.Row="3">
                                <Button Content="Remove Selected" Command="{Binding RemoveWaypointCommand}" Padding="12,8" Margin="0,0,0,8" />
                                <UniformGrid Columns="2">
                                    <Button Content="Save Mission" Command="{Binding SaveMissionCommand}" Padding="12,8" Margin="0,0,4,0" />
                                    <Button Content="Load Mission" Command="{Binding LoadMissionCommand}" Padding="12,8" Margin="4,0,0,0" />
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            
            <TabItem Header="Runtime Validation">
                <Grid Background="{StaticResource SurfaceBrush}" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,14">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Runtime Validation" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="Deployment feasibility status for managed external runtimes" Foreground="#667085" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Refresh"
                                Command="{Binding RefreshRuntimeValidationCommand}"
                                Padding="18,9"
                                HorizontalAlignment="Right" />
                    </DockPanel>

                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
                        <DataGrid ItemsSource="{Binding RuntimeValidationItems}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Dependency" Binding="{Binding Dependency}" Width="2*" />
                                <DataGridTextColumn Header="Installed" Binding="{Binding Installed}" Width="*" />
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="1.5*" />
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="3*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            
            <TabItem Header="Telemetry Replay">
                <Grid DataContext="{Binding ReplayViewModel}" Background="{StaticResource SurfaceBrush}" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14" Margin="0,0,14,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Recorded Sessions" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#17242E" CornerRadius="4" Padding="10" Margin="0,0,0,5" MinWidth="240">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                <TextBlock Text="{Binding StartTime, StringFormat=G}" Foreground="#B7C9D1" FontSize="11" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="2">
                                <Button Content="Load Session" Command="{Binding LoadSelectedSessionCommand}" Padding="12,8" Margin="0,0,0,4" />
                                <Button Content="Refresh List" Command="{Binding LoadSessionsCommand}" Padding="12,8" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1.5*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Telemetry Readout" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            
                            <Border Grid.Row="1" Background="Black" CornerRadius="8" ClipToBounds="True" Margin="0,0,0,10">
                                <ffme:MediaElement x:Name="ReplayVideo" LoadedBehavior="Pause" />
                            </Border>

                            <UniformGrid Grid.Row="2" Columns="2" Rows="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel Margin="20">
                                    <TextBlock Text="Battery" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding BatteryLabel}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Speed" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Speed}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Altitude" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Altitude}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Flight Mode" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding FlightMode}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Latitude" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Latitude}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Longitude" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Longitude}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </UniformGrid>
                            
                            <Border Grid.Row="3" Background="#101820" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Timeline" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding TimelineLabel}" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" DockPanel.Dock="Right" VerticalAlignment="Center" />
                                        <Slider Value="{Binding CurrentTimeSeconds}" Maximum="{Binding TotalTimeSeconds}" Minimum="0" Margin="10,0" TickFrequency="1" IsSnapToTickEnabled="False" />
                                    </DockPanel>
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <Button Content="Play" Command="{Binding PlayCommand}" Padding="20,8" Margin="0,0,10,0" Background="#1B4D3E" />
                                            <Button Content="Pause" Command="{Binding PauseCommand}" Padding="20,8" Background="#7B2CBF" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                            <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <ComboBox ItemsSource="{Binding AvailableSpeeds}" SelectedItem="{Binding SelectedPlaybackSpeed}" Width="80" Padding="5">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0}x}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
