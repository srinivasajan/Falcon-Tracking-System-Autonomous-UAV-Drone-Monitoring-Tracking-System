<Window x:Class="DroneControl.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        xmlns:ffme="clr-namespace:Unosquare.FFME;assembly=ffme.win"
        Title="DroneControl"
        Height="820"
        Width="1280"
        MinHeight="720"
        MinWidth="1100"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="DroneControl" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="Provider-based operations dashboard" FontSize="14" Foreground="#667085" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Start Providers" Command="{Binding StartProvidersCommand}" Padding="18,9" Margin="0,0,10,0" ToolTip="Starts all drone, vision, tracking, telemetry, and mission services." />
                <Button Content="Stop" Command="{Binding StopProvidersCommand}" Padding="18,9" ToolTip="Stops all running services and disconnects from the drone." />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Dashboard">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" /> <!-- Left Panel: Getting Started, Status, Feed -->
            <ColumnDefinition Width="2.5*" /> <!-- Center Panel: Camera Feed & Empty State -->
            <ColumnDefinition Width="1.5*" /> <!-- Right Panel: Drone Status, Pursuit Controls, Telemetry -->
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
            <StackPanel>
                <!-- Getting Started Guide -->
                <Expander Header="Getting Started" IsExpanded="True" Foreground="White" Background="{StaticResource PanelBrush}" Margin="0,0,0,16">
                    <StackPanel Margin="10">
                        <CheckBox Content="1. Start Providers" IsChecked="{Binding IsStep1Complete, Mode=OneWay}" IsHitTestVisible="False" Foreground="White" Margin="0,4"/>
                        <CheckBox Content="2. Connect Drone/Sim" IsChecked="{Binding IsStep2Complete, Mode=OneWay}" IsHitTestVisible="False" Foreground="White" Margin="0,4"/>
                        <CheckBox Content="3. Target Detected" IsChecked="{Binding IsStep3Complete, Mode=OneWay}" IsHitTestVisible="False" Foreground="White" Margin="0,4"/>
                        <CheckBox Content="4. Target Locked" IsChecked="{Binding IsStep4Complete, Mode=OneWay}" IsHitTestVisible="False" Foreground="White" Margin="0,4"/>
                        <CheckBox Content="5. Auto Pursuit Enabled" IsChecked="{Binding IsStep5Complete, Mode=OneWay}" IsHitTestVisible="False" Foreground="White" Margin="0,4"/>
                        <CheckBox Content="6. Telemetry Received" IsChecked="{Binding IsStep6Complete, Mode=OneWay}" IsHitTestVisible="False" Foreground="White" Margin="0,4"/>
                        
                        <Button Content="Run Demo Mode" Command="{Binding RunDemoCommand}" Margin="0,15,0,0" Padding="8,5" ToolTip="Runs a 10s simulation of the full tracking pipeline without real hardware."/>
                    </StackPanel>
                </Expander>

                <!-- System Status -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="System Status" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="White" />
                        <UniformGrid Columns="2" Rows="6">
                            <TextBlock Text="Drone:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Vision:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding VisionSystemStatus}" Foreground="White"/>
                            <TextBlock Text="Detection:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding TargetDetectionStatus}" Foreground="White"/>
                            <TextBlock Text="Tracker:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding TrackerStatus}" Foreground="White"/>
                            <TextBlock Text="Navigation:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding NavigationStatus}" Foreground="White"/>
                            <TextBlock Text="Safety:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding SafetyStatus}" Foreground="#35D0BA"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Operator Event Feed -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Operator Event Feed" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="White" />
                        <ItemsControl ItemsSource="{Binding EventFeed}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,4" Foreground="#B7C9D1" TextWrapping="Wrap">
                                        <Run Text="{Binding Timestamp, StringFormat='HH:mm:ss '}" Foreground="#667085"/>
                                        <Run Text="{Binding Message}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Center Panel: Camera Feed -->
        <Border Grid.Column="1" Background="#101820" CornerRadius="8" Padding="16" Margin="0,0,16,16">
            <Grid>
                <TextBlock Text="OPERATOR CAMERA VIEW" Foreground="#B7C9D1" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" />
                
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCameraFeed}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No camera feed available." Foreground="White" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="To begin:" Foreground="#B7C9D1" FontSize="16" Margin="0,0,0,5"/>
                    <TextBlock Text="1. Click 'Start Providers' (top right)" Foreground="#B7C9D1" FontSize="16" Margin="10,2,0,2"/>
                    <TextBlock Text="2. Connect to Simulation or Drone" Foreground="#B7C9D1" FontSize="16" Margin="10,2,0,2"/>
                    <TextBlock Text="3. Wait for vision processing to start" Foreground="#B7C9D1" FontSize="16" Margin="10,2,0,2"/>
                </StackPanel>

                <!-- Video Feed -->
                <Grid Margin="0,32,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCameraFeed}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <ffme:MediaElement x:Name="LiveVideo" Background="#17242E" LoadedBehavior="Play" />
                    <Canvas Background="Transparent">
                        <ItemsControl ItemsSource="{Binding Detections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.LockTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            BorderBrush="#35D0BA"
                                            BorderThickness="2"
                                            ToolTip="Select this detected target for continuous tracking"
                                            Width="{Binding Width}"
                                            Height="{Binding Height}">
                                        <StackPanel VerticalAlignment="Top" Background="#CC101820">
                                            <TextBlock Text="{Binding ObjectType}" Foreground="White" FontWeight="SemiBold" Margin="4,2" />
                                            <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}" Foreground="#35D0BA" Margin="4,0,4,2" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Grid>
                
                <TextBlock Text="{Binding FrameLabel}" Foreground="#B7C9D1" FontFamily="Consolas" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
            </Grid>
        </Border>

        <!-- Right Panel: Drone Status, Pursuit, Telemetry -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
            <StackPanel>
                <!-- Autonomous Pursuit Controls -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Autonomous Pursuit" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,14" />
                        <TextBlock Text="{Binding AutoTrackingStatusLabel}" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                        
                        <UniformGrid Columns="2" Rows="2" Margin="0,0,0,16">
                            <TextBlock Text="Target Class:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding TargetClassLabel}" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Text="Confidence:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding TargetConfidenceLabel}" Foreground="White" FontWeight="Bold"/>
                        </UniformGrid>

                        <UniformGrid Columns="2">
                            <Button Content="▶ Start Pursuit" Command="{Binding StartAutoTrackingCommand}" Padding="12,12" Margin="0,0,4,0" Background="#1B4D3E" ToolTip="Engages autopilot to physically follow the locked target." />
                            <Button Content="■ Stop Pursuit" Command="{Binding StopAutoTrackingCommand}" Padding="12,12" Margin="4,0,0,0" Background="#7B1818" ToolTip="Disengages autopilot tracking. Drone will hold position."/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Drone Flight Controls -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Flight Controls" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,14" />
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Battery" Foreground="#B7C9D1"/>
                                <TextBlock Text="{Binding BatteryLabel}" Foreground="White"/>
                            </StackPanel>
                            <ProgressBar Grid.Column="1" Value="{Binding BatteryPercent, Mode=OneWay}" Maximum="100" Width="100" Height="14" VerticalAlignment="Center" />
                        </Grid>
                        
                        <UniformGrid Columns="2" Rows="3" Margin="0,0,0,16">
                            <TextBlock Text="Altitude:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding Altitude}" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Text="Speed:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding Speed}" Foreground="White" FontWeight="Bold"/>
                            <TextBlock Text="Flight Mode:" Foreground="#B7C9D1"/>
                            <TextBlock Text="{Binding FlightMode}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                        </UniformGrid>

                        <UniformGrid Columns="2">
                            <Button Content="Arm" Command="{Binding ArmCommand}" Padding="12,8" Margin="0,0,4,4" ToolTip="Arms the vehicle's motors."/>
                            <Button Content="Takeoff" Command="{Binding TakeoffCommand}" Padding="12,8" Margin="4,0,0,4" ToolTip="Commands the drone to automatically take off and hover."/>
                            <Button Content="Disarm" Command="{Binding DisarmCommand}" Padding="12,8" Margin="0,4,4,0" ToolTip="Disarms the vehicle's motors."/>
                            <Button Content="Land" Command="{Binding LandCommand}" Padding="12,8" Margin="4,4,0,0" ToolTip="Commands the drone to land at its current location."/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Telemetry Stream -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Live Telemetry" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10" />
                        
                        <!-- Empty state for Telemetry -->
                        <TextBlock Text="Waiting for drone connection..." Foreground="#667085" Margin="0,10,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasTelemetry}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding TelemetryLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" Margin="0,0,0,5" Foreground="#B7C9D1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</TabItem>
            
            <TabItem Header="Mission Planner">
                <Grid Background="{StaticResource SurfaceBrush}" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Margin="0,0,14,0" Background="#101820">
                        <mapsui:MapControl x:Name="MapControl" />
                    </Border>
                    
                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Mission Planning" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="1" Text="Click the map to place waypoints." Foreground="#667085" Margin="0,0,0,10" TextWrapping="Wrap" />
                            
                            <ListBox Grid.Row="2" ItemsSource="{Binding MissionWaypoints}" SelectedItem="{Binding SelectedWaypoint}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#17242E" CornerRadius="4" Padding="10" Margin="0,0,0,5" MinWidth="260">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Sequence, StringFormat=Waypoint {0}}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                <TextBlock Text="{Binding Latitude, StringFormat=Lat: {0:F5}}" Foreground="#B7C9D1" />
                                                <TextBlock Text="{Binding Longitude, StringFormat=Lon: {0:F5}}" Foreground="#B7C9D1" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            
                            <StackPanel Grid.Row="3">
                                <Button Content="Remove Selected" Command="{Binding RemoveWaypointCommand}" Padding="12,8" Margin="0,0,0,8" />
                                <UniformGrid Columns="2">
                                    <Button Content="Save Mission" Command="{Binding SaveMissionCommand}" Padding="12,8" Margin="0,0,4,0" />
                                    <Button Content="Load Mission" Command="{Binding LoadMissionCommand}" Padding="12,8" Margin="4,0,0,0" />
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
            
            <TabItem Header="Runtime Validation">
                <Grid Background="{StaticResource SurfaceBrush}" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,14">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Runtime Validation" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="Deployment feasibility status for managed external runtimes" Foreground="#667085" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Refresh"
                                Command="{Binding RefreshRuntimeValidationCommand}"
                                Padding="18,9"
                                HorizontalAlignment="Right" />
                    </DockPanel>

                    <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
                        <DataGrid ItemsSource="{Binding RuntimeValidationItems}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Dependency" Binding="{Binding Dependency}" Width="2*" />
                                <DataGridTextColumn Header="Installed" Binding="{Binding Installed}" Width="*" />
                                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="1.5*" />
                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="3*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            
            <TabItem Header="Telemetry Replay">
                <Grid DataContext="{Binding ReplayViewModel}" Background="{StaticResource SurfaceBrush}" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14" Margin="0,0,14,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Recorded Sessions" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            <ListBox Grid.Row="1" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#17242E" CornerRadius="4" Padding="10" Margin="0,0,0,5" MinWidth="240">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                <TextBlock Text="{Binding StartTime, StringFormat=G}" Foreground="#B7C9D1" FontSize="11" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="2">
                                <Button Content="Load Session" Command="{Binding LoadSelectedSessionCommand}" Padding="12,8" Margin="0,0,0,4" />
                                <Button Content="Refresh List" Command="{Binding LoadSessionsCommand}" Padding="12,8" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1.5*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Telemetry Readout" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            
                            <Border Grid.Row="1" Background="Black" CornerRadius="8" ClipToBounds="True" Margin="0,0,0,10">
                                <ffme:MediaElement x:Name="ReplayVideo" LoadedBehavior="Pause" />
                            </Border>

                            <UniformGrid Grid.Row="2" Columns="2" Rows="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel Margin="20">
                                    <TextBlock Text="Battery" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding BatteryLabel}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Speed" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Speed}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Altitude" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Altitude}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Flight Mode" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding FlightMode}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Latitude" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Latitude}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="20">
                                    <TextBlock Text="Longitude" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Longitude}" FontSize="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </UniformGrid>
                            
                            <Border Grid.Row="3" Background="#101820" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Timeline" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding TimelineLabel}" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" DockPanel.Dock="Right" VerticalAlignment="Center" />
                                        <Slider Value="{Binding CurrentTimeSeconds}" Maximum="{Binding TotalTimeSeconds}" Minimum="0" Margin="10,0" TickFrequency="1" IsSnapToTickEnabled="False" />
                                    </DockPanel>
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <Button Content="Play" Command="{Binding PlayCommand}" Padding="20,8" Margin="0,0,10,0" Background="#1B4D3E" />
                                            <Button Content="Pause" Command="{Binding PauseCommand}" Padding="20,8" Background="#7B2CBF" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                            <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <ComboBox ItemsSource="{Binding AvailableSpeeds}" SelectedItem="{Binding SelectedPlaybackSpeed}" Width="80" Padding="5">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0}x}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
